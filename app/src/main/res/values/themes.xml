<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyBookCatalog" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2C3E50</item> <!-- Midnight Blue -->
        <item name="colorSecondary">#E67E22</item> <!-- Alibaba-style Orange -->
        <item name="android:windowBackground">#FDFCFB</item> <!-- Creamy Paper Background -->
    </style>

    <style name="Theme.MyBookCatalog" parent="Base.Theme.MyBookCatalog" />

    <style name="AlibabaCategoryTab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#7F8C8D</item>
        <item name="android:background">@drawable/bg_category_pill</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>